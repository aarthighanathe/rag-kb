# ============================================================
# RAG Knowledge Base — Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Backend API base URL ---
# Absolute backend URL — only needed when frontend/backend aren't on the same
# origin (e.g. deploying to Vercel while the backend runs on Render). Leave
# unset for local dev to use the Vite dev proxy ('/api', see vite.config.ts).
VITE_API_BASE_URL=http://localhost:3000/api

# --- Authentication (Clerk — Google OAuth only) ---
# Clerk Dashboard → API Keys (starts with pk_). Must be the same value as the
# backend's CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=

# --- Upload size limit (client-side pre-check only) ---
# Must match the backend's MAX_FILE_SIZE_MB (backend/.env) — this only lets
# the UI reject oversized files before upload; the backend independently
# re-validates and is the real source of truth. Defaults to 10 if unset.
VITE_MAX_FILE_SIZE_MB=10

# --- Playwright e2e: Clerk test session (@clerk/testing) ---
# Only needed to run playwright/e2e/auth.spec.ts's signed-in test cases.
# CLERK_SECRET_KEY: same value as backend/.env's CLERK_SECRET_KEY (test instance only —
#   clerkSetup() throws if given a production secret key).
# E2E_CLERK_USER_EMAIL / E2E_CLERK_USER_PASSWORD: a dedicated, disposable test user
#   created via the Clerk Backend API (clerk.users.createUser) — never a real account.
#   Password-strategy sign-in works via the Backend API even though the app's UI only
#   exposes Google OAuth, since @clerk/testing signs in below the UI layer.
CLERK_SECRET_KEY=
E2E_CLERK_USER_EMAIL=
E2E_CLERK_USER_PASSWORD=
