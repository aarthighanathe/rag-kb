{
  "name": "rag-kb-backend",
  "version": "1.0.0",
  "description": "RAG Knowledge Base — Express 5 backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts --fix",
    "lint:check": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "complexity-audit": "eslint src --ext .ts --rule \"{\\\"complexity\\\": [\\\"error\\\", 10]}\"",
    "swagger-validate": "tsx --env-file .env scripts/validate-swagger.ts",
    "db:migrate": "tsx --env-file .env scripts/migrate.ts",
    "db:status": "tsx --env-file .env scripts/migrate.ts --status",
    "db:check": "tsx --env-file .env scripts/check-supabase.ts",
    "db:setup": "tsx --env-file .env scripts/migrate.ts && tsx --env-file .env scripts/check-supabase.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.10.0",
    "@supabase/supabase-js": "^2.46.2",
    "bullmq": "^5.34.5",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "mammoth": "^1.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
