# ============================================================
# RAG Knowledge Base — Backend Environment Variables
# Copy this file to backend/.env and fill in all values.
# NEVER commit backend/.env to version control.
# ============================================================

# --- LLM & Embeddings ---
GROQ_API_KEY=                        # console.groq.com → API Keys
HUGGINGFACE_TOKEN=                   # huggingface.co/settings/tokens (read role)

# --- Supabase (remote — no local container) ---
SUPABASE_URL=                        # Project → API → Project URL
SUPABASE_SERVICE_KEY=                # Project → API → service_role key (NOT anon)
DATABASE_URL=                        # Project → Database → Connection string (URI). Used by npm run db:migrate
                                     # Example: postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Redis (local via docker-compose, or Upstash for prod) ---
# IMPORTANT: REDIS_PASSWORD (below) is NOT read by the app directly — it only
# feeds docker-compose.yml's --requirepass. The app authenticates to Redis
# using whatever credentials are embedded IN REDIS_URL itself. Compose starts
# a password-protected Redis, so REDIS_URL below MUST embed that same
# password (redis://:PASSWORD@host:port) or every BullMQ connection fails
# with NOAUTH and document ingestion silently stops working. 127.0.0.1 (not
# "localhost") avoids Node resolving to the IPv6 loopback (::1), which the
# docker-compose port mapping doesn't listen on.
REDIS_URL=redis://:changeme@127.0.0.1:6379     # Must match REDIS_PASSWORD below
REDIS_PASSWORD=changeme                        # REQUIRED — no default. Only consumed by
                                                # docker-compose.yml's --requirepass; must be
                                                # the same value embedded in REDIS_URL above.
                                                # `docker-compose up` fails fast with a clear
                                                # error if this is unset. Generate a strong
                                                # value for anything beyond local dev, e.g.:
                                                # openssl rand -base64 24

# --- Server ---
PORT=3000
NODE_ENV=development                 # development | production | test

# --- CORS ---
CORS_ORIGIN=http://localhost:5173    # Must be the exact frontend origin (no trailing /)

# --- File Upload ---
MAX_FILE_SIZE_MB=10                  # Max file size per upload (each file)

# --- Rate Limiting (all per window) ---
RATE_LIMIT_WINDOW_MS=60000           # Rolling window in milliseconds (default: 60s)
RATE_LIMIT_MAX_UPLOAD=5             # Max uploads per IP per window
RATE_LIMIT_MAX_QUERY=30             # Max queries per IP per window
RATE_LIMIT_MAX_DOCUMENTS=100        # Max document list/delete requests per IP per window

# --- Admin ---
ADMIN_SECRET=                                  # Passed via X-Admin-Secret header (min 32 chars)

# --- Authentication (Clerk — Google OAuth only) ---
CLERK_SECRET_KEY=                    # Clerk Dashboard → API Keys (starts with sk_)
CLERK_PUBLISHABLE_KEY=               # Clerk Dashboard → API Keys (starts with pk_)

# --- Logging ---
LOG_LEVEL=info                       # error | warn | info | debug

# --- Frontend ---
# The frontend reads its own separate env file — see frontend/.env.example.
# (Vite never reads this file; VITE_* vars set here have no effect.)
