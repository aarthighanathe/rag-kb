{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@services/*": ["./src/services/*"],
      "@middleware/*": ["./src/middleware/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@utils/*": ["./src/utils/*"],
      "@types/*": ["./src/types/*"],
      "@queues/*": ["./src/queues/*"],
      "@config/*": ["./src/config/*"],
      "@routes/*": ["./src/routes/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
