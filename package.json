{
  "name": "rag-kb",
  "version": "1.0.0",
  "description": "RAG Knowledge Base monorepo root",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "quality-check": "npm run lint --prefix backend && npm run type-check --prefix backend && npm run test --prefix backend && npm run complexity-audit --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:status": "npm run db:status --prefix backend",
    "db:check": "npm run db:check --prefix backend",
    "db:setup": "npm run db:setup --prefix backend",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
